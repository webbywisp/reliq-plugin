#!/usr/bin/env node
// reliq — executable entry for the Reliq CLI (Claude Code plugin engine).
//
// Thin wrapper: resolves the CLI source next to this bin dir and dispatches.
// Implemented as a Node ES module so there's no build step — `bin/reliq` runs
// directly with only Node stdlib + git/curl. Hook commands (context/capture)
// fail safe (exit 0) so a coding session is never blocked.

import { fileURLToPath } from "node:url";
import { dirname, join } from "node:path";

const __dirname = dirname(fileURLToPath(import.meta.url));
const mainPath = join(__dirname, "..", "cli", "main.mjs");

const { run } = await import(mainPath);

try {
  const code = await run(process.argv.slice(2));
  process.exitCode = typeof code === "number" ? code : 0;
} catch (err) {
  // Last-resort guard: never throw out of the process. Hook paths still want a
  // clean exit; this only fires for truly unexpected errors.
  process.stderr.write(`reliq: fatal: ${err?.message || err}\n`);
  process.exitCode = 1;
}
